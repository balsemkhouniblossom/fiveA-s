pipeline {
    agent any
    stages {
        stage('Install Dependencies') {
            steps {
                // Navigate to the backend folder before installing dependencies
                dir('server') {
                    sh 'npm install'
                }
            }
        }

        stage('Run Unit Tests') {
            steps {
                // Navigate to the backend folder before running tests
                dir('server') {
                    sh 'npm test'
                }
            }
        }

        stage('SonarQube Analysis') { 
            steps {
                dir('server') { // Exécution de SonarQube dans le dossier 'server'
                    
                       def scannerHome = tool 'scanner'
                           withSonarQubeEnv {
                             sh "${scannerHome}/bin/sonar-scanner"
                        }

                    
                }
            }
        }

        stage('Build Application') {
            steps {
                // Navigate to the backend folder before building the application
                dir('server') {
                    sh 'npm run build'
                }
            }
        }
    }
}
